NEXT_PUBLIC_ADDRESS_PROVINCE=NS
NEXT_PUBLIC_ADDRESS_POSTAL=B3J 3N8
NEXT_PUBLIC_ADDRESS_DISPLAY=1800 Argyle St, Halifax, NS B3J 3N8
